# Copy this file to .env.local and fill in your Supabase project credentials.
# Get these from: Supabase Dashboard -> Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Without these set, the app automatically runs in demo/mock mode:
# auth, uploads, and reports all work using localStorage + mock data,
# so the UI is fully explorable with zero backend setup.
